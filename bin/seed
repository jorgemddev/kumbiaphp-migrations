#!/usr/bin/env php
<?php

// Detectar raíz del proyecto
function findProjectRoot() {
    $candidates = [
        getcwd(),
        dirname(__DIR__, 2),
        dirname(__DIR__, 4),
    ];

    foreach ($candidates as $dir) {
        if ($dir && file_exists($dir . '/app/config/databases.php')) {
            return $dir;
        }
    }

    $dir = getcwd();
    for ($i = 0; $i < 6; $i++) {
        if (file_exists($dir . '/app/config/databases.php')) {
            return $dir;
        }
        $parent = dirname($dir);
        if ($parent === $dir) break;
        $dir = $parent;
    }

    return null;
}

$root = findProjectRoot();

if ($root === null) {
    echo "Error: No se encontró la raíz del proyecto KumbiaPHP.\n";
    exit(1);
}

if (!defined('APP_PATH')) {
    define('APP_PATH', $root . '/app/');
}

// Cargar autoload de Composer (buscar en ubicaciones posibles)
$autoloadCandidates = [
    $root . '/vendor/autoload.php',
    $root . '/app/libs/vendor/autoload.php',
    $root . '/app/vendor/autoload.php',
    dirname(__DIR__) . '/vendor/autoload.php',
];

$autoload = null;
foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        $autoload = $candidate;
        break;
    }
}

if ($autoload === null) {
    echo "Error: vendor/autoload.php no encontrado.\n";
    echo "Ubicaciones buscadas:\n";
    foreach ($autoloadCandidates as $c) echo "  - {$c}\n";
    echo "Ejecuta 'composer install' en el directorio donde está tu composer.json\n";
    exit(1);
}
require_once $autoload;

use JorgeMdDev\KumbiaMigrations\Seeder;

class SeederCommand
{
    protected $seedPath;

    public function __construct()
    {
        $this->seedPath = APP_PATH . 'database/seeds/';
    }

    public function run($argv)
    {
        $class = $this->getOption($argv, '--class');

        try {
            $this->runSeeder($class ?? 'DatabaseSeeder');
            $this->success("\nSeeding completed successfully!");
        } catch (Exception $e) {
            $this->error("Error: " . $e->getMessage());
            exit(1);
        }
    }

    protected function runSeeder($class)
    {
        $this->info("Seeding database...\n");
        $this->loadSeeders();

        if (!class_exists($class)) {
            throw new RuntimeException("Seeder class [{$class}] not found.");
        }

        $seeder = new $class();

        if (!($seeder instanceof Seeder)) {
            throw new RuntimeException("Class [{$class}] is not a valid Seeder.");
        }

        $this->info("Running: {$class}\n");
        $seeder->run();
    }

    protected function loadSeeders()
    {
        if (!is_dir($this->seedPath)) {
            throw new RuntimeException("Seeders directory not found: {$this->seedPath}");
        }

        foreach (glob($this->seedPath . '*.php') as $file) {
            require_once $file;
        }
    }

    protected function getOption($argv, $option)
    {
        foreach ($argv as $arg) {
            if (strpos($arg, $option . '=') === 0) {
                return substr($arg, strlen($option) + 1);
            }
        }
        return null;
    }

    protected function colorize($text, $color)
    {
        $colors = ['green' => "\033[32m", 'red' => "\033[31m", 'blue' => "\033[34m"];
        return ($colors[$color] ?? '') . $text . "\033[0m";
    }

    protected function info($msg)    { echo $this->colorize($msg, 'blue'); }
    protected function success($msg) { echo $this->colorize($msg, 'green') . "\n"; }
    protected function error($msg)   { echo $this->colorize($msg, 'red') . "\n"; }
}

(new SeederCommand())->run($argv);
